# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# User behavior: số ngày giữ event thô (job prune). Tối thiểu 7, mặc định trong code = 90 nếu không set.
USER_BEHAVIOR_RETENTION_DAYS=90

# Rollup daily: ngày UTC dạng YYYY-MM-DD (tuỳ chọn). Không set = hôm qua UTC.
# USER_BEHAVIOR_ROLLUP_DAY=2025-03-28

# JWT / app
ACCESS_TOKEN_SECRET=change-me
FRONTEND_URL=http://localhost:5173
